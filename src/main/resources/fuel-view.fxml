<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="FuelController"
      alignment="CENTER"
      spacing="10">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="lblDistance" text="Distance (km)"/>
    <TextField fx:id="txtDistance" promptText="Enter distance"/>

    <Label fx:id="lblConsumption" text="Fuel Consumption (L/100 km)"/>
    <TextField fx:id="txtConsumption" promptText="Enter consumption"/>

    <Label fx:id="lblPrice" text="Fuel Price (per liter)"/>
    <TextField fx:id="txtPrice" promptText="Enter fuel price"/>

    <Button fx:id="btnCalculate" text="Calculate Trip Cost" onAction="#calculate"/>

    <Label fx:id="lblResult" text="Result will appear here"/>

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="btnEN" text="EN" onAction="#switchToEnglish"/>
        <Button fx:id="btnFR" text="FR" onAction="#switchToFrench"/>
        <Button fx:id="btnJP" text="JP" onAction="#switchToJapanese"/>
        <Button fx:id="btnIR" text="IR" onAction="#switchToPersian"/>
    </HBox>

</VBox>